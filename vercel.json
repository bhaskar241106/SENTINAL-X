{
  "version": 2,
  "buildCommand": "npm run typecheck:libs && npm run typecheck --workspace=@workspace/drivelegal && npm run build --workspace=@workspace/drivelegal",
  "outputDirectory": "artifacts/drivelegal/dist/public",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
