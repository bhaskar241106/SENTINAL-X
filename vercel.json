{
  "version": 2,
  "buildCommand": "npm --prefix ../.. run build --workspace=@workspace/drivelegal",
  "outputDirectory": "../../artifacts/drivelegal/dist/public",
  "installCommand": "npm --prefix ../.. install --include=dev",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
